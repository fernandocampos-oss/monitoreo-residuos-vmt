# Configuración del servidor
PORT=8000

# Base de datos (Reemplazar con tus credenciales de PostgreSQL de Railway o Supabase)
# Formato: postgresql://usuario:contraseña@host:puerto/nombre_bd
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/residuos_vmt

# Seguridad (Cambiar en producción)
# Puedes generar una clave segura con: openssl rand -hex 32
JWT_SECRET=super_secret_key_for_development_purposes_only_123456
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=180

# Cloudinary (Opcional, si no se definen se activará el fallback de almacenamiento local)
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# Configuración de fallback
UPLOAD_DIR=uploads
